#!/bin/bash
# rna_seq_antibody_pipeline.sh

set -euo pipefail

# Create project structure
mkdir -p project/{raw_reads,reference,genome_index,aligned,variants,qc,logs,results}
cd project

# Install dependencies (Ubuntu/Debian)
sudo apt-get update && sudo apt-get install -y \
    fastqc \
    trimmomatic \
    samtools \
    bcftools \
    gatk4 \
    picard-tools \
    python3-pip

# Install STAR aligner
wget https://github.com/alexdobin/STAR/releases/download/2.7.11a/STAR_2.7.11a_Linux_x86_64_static.tar.gz
tar -xzf STAR_2.7.11a_Linux_x86_64_static.tar.gz
sudo cp STAR_2.7.11a_Linux_x86_64_static/Linux_x86_64_static/STAR /usr/local/bin/

# Python packages
pip3 install pandas numpy matplotlib seaborn pysam pyvcf3 \
             biopython plotly scipy scikit-learn HTSeq

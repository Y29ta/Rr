# reference/create_antibody_reference.sh

# Example: Create a FASTA reference with HC and LC from plasmid sequences
# Replace sequences below with your actual antibody sequences

cat > reference/antibody_plasmid.fa << 'EOF'
>HeavyChain|VH_CH1_CH2_CH3|IgG1

>LightChain|VL_CL|Kappa

EOF

# Index the reference
samtools faidx reference/antibody_plasmid.fa

# Create sequence dictionary
picard CreateSequenceDictionary \
    R=reference/antibody_plasmid.fa \
    O=reference/antibody_plasmid.dict

echo "Reference created and indexed."
